# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=runa
DATABASE_PASSWORD=runa
DATABASE_NAME=runa

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d

# GitHub OAuth (configure at https://github.com/settings/applications/new)
# Local dev: use http://localhost:3000/login/callback for redirect URIs and APP_URL.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://runa-app.com/login/callback

# GitLab OAuth (configure at https://gitlab.com/-/user_settings/applications)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=https://runa-app.com/login/gitlab/callback
GITLAB_BASE_URL=https://gitlab.com

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local file storage
LOCAL_STORAGE_PATH=/data/runa/uploads

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly
STRIPE_PRICE_TEAM_ANNUAL=price_team_annual
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_enterprise_annual

# Cloudflare Turnstile — optional in dev; when set, email sign-up requires a valid token
TURNSTILE_SECRET_KEY=
# Frontend: VITE_TURNSTILE_SITE_KEY (see frontend .env.example / vite-env)

# Encryption key for GitHub tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# SMTP (invitation and password-reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@runa-app.com

# App URL (used in email links, billing redirects)
APP_URL=https://runa-app.com
# Public web origin for links in Git PR bodies (often same as APP_URL)
APP_BASE_URL=https://runa-app.com

# Optional: override CORS / WebSocket allowed origins (comma-separated)
# CORS_ORIGIN=http://localhost:3000,https://runa-app.com

# Countly (backend server-side events; same app key as the web SDK)
COUNTLY_APP_KEY=
COUNTLY_SERVER_URL=https://your-countly-host

# Countly web SDK (Vite / frontend — prefix required for browser exposure)
# VITE_COUNTLY_APP_KEY=
# VITE_COUNTLY_SERVER_URL=https://your-countly-host

# ── Enterprise / On-Premise ──
# Set to "on-premise" for self-hosted deployments
DEPLOYMENT_MODE=cloud
# License key for on-premise deployments (format: runa_ent_<base64>)
LICENSE_KEY=
# Air-gapped mode disables outbound network (agent training requires network)
AIRGAPPED=false
# Local file storage path for on-premise (replaces S3)
LOCAL_STORAGE_PATH=/data/runa
# User/space limits for on-premise (0 = unlimited)
MAX_USERS=0
MAX_SPACES=0
